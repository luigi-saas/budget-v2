# ─────────────────────────────────────────────────────────────
# Flousy — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string used by Drizzle ORM.
# For Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ── Supabase ─────────────────────────────────────────────────
# Found in your Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Node ─────────────────────────────────────────────────────
# Set to "production" in deployed environments.
# NODE_ENV=production
